ANTHROPIC_API_KEY=sk-ant-your-key-here

# GitHub organization for project repos (default: cordada)
GITHUB_ORG=cordada

# Directory where project repos are cloned (default: ./projects)
# PROJECTS_DIR=/path/to/projects

# --- Google Workspace Integration (optional) ---
# Service account credentials JSON file. Required for Drive, Gmail, Calendar tools.
# See: https://cloud.google.com/iam/docs/service-accounts-create
# GOOGLE_CREDENTIALS_PATH=/path/to/service-account.json

# If using domain-wide delegation, the email address to impersonate.
# GOOGLE_DELEGATE_EMAIL=ceo@cordada.com

# --- Slack Integration (optional) ---
# Bot User OAuth Token. Required for Slack search, read, and send tools.
# Create app at https://api.slack.com/apps → OAuth & Permissions
# Required scopes: search:read, channels:history, chat:write
# SLACK_BOT_TOKEN=xoxb-your-bot-token
